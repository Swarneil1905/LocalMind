{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalMind",
  "version": "0.5.6",
  "identifier": "com.localmind.desktop",
  "build": {
    "beforeDevCommand": "npx vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npx vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalMind",
        "width": 1280,
        "height": 820,
        "minWidth": 768,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQwQ0JBRUU1QzU2NzM4QjIKUldTeU9HZkY1YTdMMEFKUVVabXhPNEhFVkF2T045MUcwNWlhYWJiZG5DQ0t0azZWSS8xMTJ0Y3YK",
      "endpoints": [
        "https://github.com/Swarneil1905/LocalMind/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ollama",
      "binaries/localmind-sidecar"
    ]
  }
}